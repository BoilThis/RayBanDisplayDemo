<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF">

    <!-- PREMIUM IVORY GRADIENT HEADER -->
    <View
        android:id="@+id/headerGradient"
        android:layout_width="match_parent"
        android:layout_height="220dp"
        android:background="@drawable/wegmans_header_gradient_light"
        app:layout_constraintTop_toTopOf="parent" />

    <LinearLayout
        android:id="@+id/headerBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="32dp"
        app:layout_constraintTop_toTopOf="parent">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="WEGMANS ELITE"
                android:textColor="#006938"
                android:letterSpacing="0.5"
                android:textSize="10sp"
                android:textStyle="bold"
                android:layout_alignParentStart="true"/>

            <TextView
                android:id="@+id/devicesText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="LINK ACTIVE"
                android:textColor="#006938"
                android:textSize="10sp"
                android:textStyle="bold"
                android:letterSpacing="0.1"
                android:layout_alignParentEnd="true"
                android:alpha="0.8"/>
        </RelativeLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Store Audit"
            android:textColor="#1A1A1A"
            android:textSize="32sp"
            android:fontFamily="sans-serif-light" />

        <!-- COMPACT BOLD DEPARTMENT DASHBOARD -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="16dp"
            android:gravity="center_vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="DEPT:"
                android:textColor="#000000"
                android:textSize="14sp"
                android:textStyle="bold" />

            <Spinner
                android:id="@+id/deptSpinner"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="4dp"
                android:backgroundTint="#006938" />

            <TextView
                android:id="@+id/progressStats"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:text="0% COMPLETE"
                android:textColor="#000000"
                android:textSize="14sp"
                android:textStyle="bold" />
        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="12dp"
            android:background="#EEEEEE" />

    </LinearLayout>

    <FrameLayout
        android:id="@+id/contentFrame"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintBottom_toTopOf="@+id/bottomNavigation"
        app:layout_constraintTop_toBottomOf="@id/headerBar">

        <!-- TASKS SECTION -->
        <ScrollView
            android:id="@+id/tasksSection"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:paddingHorizontal="16dp"
            android:clipToPadding="false"
            android:visibility="visible">
            <LinearLayout
                android:id="@+id/taskListContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingTop="8dp"
                android:paddingBottom="120dp" />
        </ScrollView>

        <!-- GLASS SECTION -->
        <LinearLayout
            android:id="@+id/glassSection"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="32dp"
            android:visibility="gone">

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="#F9F8F2"
                app:cardCornerRadius="16dp"
                app:strokeColor="#EEEEEE"
                app:strokeWidth="1dp"
                app:cardElevation="2dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="24dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="DEVICE LINK"
                        android:textColor="#006938"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.2" />

                    <Button
                        android:id="@+id/btnResync"
                        android:layout_width="match_parent"
                        android:layout_height="64dp"
                        android:layout_marginTop="16dp"
                        android:text="RECALIBRATE HUD"
                        android:backgroundTint="#006938"
                        android:textColor="#FFFFFF"
                        app:cornerRadius="8dp" />

                    <Button
                        android:id="@+id/registerButton"
                        android:layout_width="match_parent"
                        android:layout_height="64dp"
                        android:layout_marginTop="12dp"
                        android:text="PAIR NEW GLASSES"
                        android:backgroundTint="#EEEEEE"
                        android:textColor="#333333"
                        app:cornerRadius="8dp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <Button
                android:id="@+id/btnMockVoice"
                android:layout_width="match_parent"
                android:layout_height="64dp"
                android:layout_marginTop="24dp"
                android:text="MANUAL VOICE TRIGGER"
                android:backgroundTint="#006938"
                android:textColor="#FFFFFF"
                app:cornerRadius="8dp" />
        </LinearLayout>

        <!-- REPORT SECTION -->
        <LinearLayout
            android:id="@+id/reportSection"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="32dp"
            android:visibility="gone">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="AUDIT SUMMARY"
                android:textColor="#1A1A1A"
                android:textSize="20sp"
                android:layout_marginBottom="32dp" />

            <Button
                android:id="@+id/btnGenerateReport"
                android:layout_width="match_parent"
                android:layout_height="64dp"
                android:text="FINALIZE &amp; EXPORT"
                android:backgroundTint="#006938"
                android:textColor="#FFFFFF"
                app:cornerRadius="8dp" />

            <Button
                android:id="@+id/btnClearTasks"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="40dp"
                android:text="RESET ALL DATA"
                style="@style/Widget.Material3.Button.TextButton"
                android:textColor="#FF4444" />
        </LinearLayout>

        <!-- USER ADMINISTRATION SECTION (STYLIZED) -->
        <ScrollView
            android:id="@+id/userSection"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:paddingHorizontal="16dp"
            android:clipToPadding="false"
            android:visibility="gone">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingBottom="120dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="USER ADMINISTRATION"
                    android:textColor="#006938"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:layout_marginTop="24dp"
                    android:layout_marginBottom="16dp" />

                <!-- FORM CARD -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardBackgroundColor="#F9F8F2"
                    app:cardCornerRadius="16dp"
                    app:strokeColor="#006938"
                    app:strokeWidth="2dp"
                    app:cardElevation="4dp"
                    android:layout_marginBottom="32dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="24dp">

                        <EditText
                            android:id="@+id/editFirstName"
                            android:layout_width="match_parent"
                            android:layout_height="56dp"
                            android:hint="First Name"
                            android:inputType="textPersonName"
                            android:background="#FFFFFF"
                            android:paddingHorizontal="16dp"
                            android:textColor="#000000"
                            android:textColorHint="#999999"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:layout_marginBottom="12dp" />

                        <EditText
                            android:id="@+id/editLastName"
                            android:layout_width="match_parent"
                            android:layout_height="56dp"
                            android:hint="Last Name"
                            android:inputType="textPersonName"
                            android:background="#FFFFFF"
                            android:paddingHorizontal="16dp"
                            android:textColor="#000000"
                            android:textColorHint="#999999"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:layout_marginBottom="12dp" />

                        <EditText
                            android:id="@+id/editEmployeeId"
                            android:layout_width="match_parent"
                            android:layout_height="56dp"
                            android:hint="Employee ID"
                            android:inputType="number"
                            android:background="#FFFFFF"
                            android:paddingHorizontal="16dp"
                            android:textColor="#000000"
                            android:textColorHint="#999999"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:layout_marginBottom="12dp" />

                        <EditText
                            android:id="@+id/editPassword"
                            android:layout_width="match_parent"
                            android:layout_height="56dp"
                            android:hint="Access PIN"
                            android:inputType="numberPassword"
                            android:background="#FFFFFF"
                            android:paddingHorizontal="16dp"
                            android:textColor="#000000"
                            android:textColorHint="#999999"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:layout_marginBottom="16dp" />

                        <Button
                            android:id="@+id/btnSelectDepts"
                            android:layout_width="match_parent"
                            android:layout_height="56dp"
                            android:text="MANAGE DEPARTMENT ACCESS"
                            style="@style/Widget.Material3.Button.OutlinedButton"
                            app:strokeColor="#006938"
                            android:textColor="#006938"
                            android:layout_marginBottom="24dp" />

                        <Button
                            android:id="@+id/btnSaveUser"
                            android:layout_width="match_parent"
                            android:layout_height="64dp"
                            android:text="REGISTER USER"
                            android:backgroundTint="#006938"
                            android:textColor="#FFFFFF"
                            android:textSize="16sp"
                            android:textStyle="bold" />

                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="REGISTERED ELITE PERSONNEL"
                    android:textColor="#000000"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="16dp" />

                <LinearLayout
                    android:id="@+id/userListContainer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical" />

            </LinearLayout>
        </ScrollView>
    </FrameLayout>

    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottomNavigation"
        android:layout_width="match_parent"
        android:layout_height="72dp"
        android:background="#FFFFFF"
        app:itemIconTint="@color/nav_item_color_light"
        app:itemTextColor="@color/nav_item_color_light"
        app:layout_constraintBottom_toBottomOf="parent"
        app:menu="@menu/bottom_nav_menu"
        app:labelVisibilityMode="labeled" />

</androidx.constraintlayout.widget.ConstraintLayout>
