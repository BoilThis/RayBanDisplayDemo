<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF">

    <!-- Minimalist Header Bar -->
    <LinearLayout
        android:id="@+id/headerBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#FFFFFF"
        android:orientation="vertical"
        android:paddingHorizontal="24dp"
        android:paddingVertical="16dp"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:id="@+id/statusText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="GLASSTASKS"
            android:textColor="#000000"
            android:letterSpacing="0.2"
            android:textSize="11sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/devicesText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:text="Searching for Mike..."
            android:textColor="#757575"
            android:textSize="13sp" />

        <View
            android:layout_width="40dp"
            android:layout_height="2dp"
            android:layout_marginTop="8dp"
            android:background="#000000" />
    </LinearLayout>

    <!-- MAIN CONTENT AREA -->
    <FrameLayout
        android:id="@+id/fragmentContainer"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintBottom_toTopOf="@+id/bottomNavigation"
        app:layout_constraintTop_toBottomOf="@id/headerBar">

        <!-- TAB 1: WORKLIST -->
        <ScrollView
            android:id="@+id/tasksSection"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:paddingHorizontal="16dp"
            android:visibility="visible">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingTop="8dp">

                <LinearLayout
                    android:id="@+id/taskListContainer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="100dp" /> <!-- Bottom padding for FAB -->
            </LinearLayout>
        </ScrollView>

        <!-- TAB 2: COCKPIT / CONTROL -->
        <LinearLayout
            android:id="@+id/glassSection"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center_horizontal"
            android:orientation="vertical"
            android:padding="32dp"
            android:visibility="gone">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="MIKE CONTROL"
                android:textColor="#000000"
                android:letterSpacing="0.1"
                android:textSize="18sp"
                android:textStyle="bold" />

            <Button
                android:id="@+id/btnDisplay"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="40dp"
                android:text="RE-SYNC HUD"
                android:backgroundTint="#000000"
                android:textColor="#FFFFFF"
                app:cornerRadius="4dp" />

            <Button
                android:id="@+id/btnCamera"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="12dp"
                android:text="WAKE CAMERA"
                android:backgroundTint="#F2F2F2"
                android:textColor="#000000"
                app:cornerRadius="4dp" />

            <TextureView
                android:id="@+id/cameraPreview"
                android:layout_width="match_parent"
                android:layout_height="220dp"
                android:layout_marginTop="24dp"
                android:visibility="gone" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="40dp"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/registerButton"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="PAIR"
                    style="@style/Widget.Material3.Button.TextButton"
                    android:textColor="#000000" />

                <Button
                    android:id="@+id/resetButton"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="RESET"
                    style="@style/Widget.Material3.Button.TextButton"
                    android:textColor="#000000" />
            </LinearLayout>

            <TextView android:id="@+id/imuText" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone"/>
            <TextView android:id="@+id/gestureText" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone"/>
        </LinearLayout>

        <!-- TAB 3: ANALYTICS / REPORT -->
        <LinearLayout
            android:id="@+id/reportSection"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="32dp"
            android:visibility="gone">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ANALYTICS"
                android:textColor="#000000"
                android:letterSpacing="0.1"
                android:textSize="18sp"
                android:textStyle="bold" />

            <Button
                android:id="@+id/btnGenerateReport"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="40dp"
                android:backgroundTint="#000000"
                android:text="GENERATE PDF REPORT"
                android:textColor="#FFFFFF"
                app:cornerRadius="4dp" />

            <Button
                android:id="@+id/btnClearTasks"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="40dp"
                android:text="WIPE SESSION"
                style="@style/Widget.Material3.Button.TextButton"
                android:textColor="#E53935" />

        </LinearLayout>
    </FrameLayout>

    <!-- Minimal FAB -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fabAddTask"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_margin="24dp"
        android:src="@android:drawable/ic_input_add"
        app:layout_constraintBottom_toTopOf="@id/bottomNavigation"
        app:layout_constraintEnd_toEndOf="parent"
        app:backgroundTint="#000000"
        app:tint="#FFFFFF"
        app:elevation="8dp" />

    <!-- Clean Bottom Nav -->
    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottomNavigation"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:background="#FFFFFF"
        app:itemIconTint="#000000"
        app:itemTextColor="#000000"
        app:layout_constraintBottom_toBottomOf="parent"
        app:menu="@menu/bottom_nav_menu"
        app:labelVisibilityMode="labeled" />

    <EditText android:id="@+id/taskInput" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone" app:layout_constraintStart_toStartOf="parent" app:layout_constraintTop_toTopOf="parent" android:importantForAutofill="no" android:inputType="text"/>
    <Button android:id="@+id/btnAddTask" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone" app:layout_constraintStart_toStartOf="parent" app:layout_constraintTop_toTopOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>
